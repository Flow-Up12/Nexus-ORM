model University {
  id       Int       @id @default(autoincrement())
  name     String
  founded  DateTime
  students Student[]
}

model Student {
  id           Int           @id @default(autoincrement())
  firstName    String
  lastName     String
  university   University    @relation(fields: [universityId], references: [id])
  universityId Int
  class        Course        @relation(fields: [classId], references: [id])
  classId      Int
  courseGrades CourseGrade[]
}

model CourseGrade {
  id        Int     @id @default(autoincrement())
  grade     Int
  courseId  Int
  course    Course  @relation(fields: [courseId], references: [id])
  studentId Int
  student   Student @relation(fields: [studentId], references: [id])
}

model Course {
  id           Int           @id @default(autoincrement())
  name         String
  students     Student[]
  professorId  Int?          // nullable if a course may be unassigned
  professor    Professor?    @relation(fields: [professorId], references: [id])
  courseGrades CourseGrade[]
}

model Professor {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  courses   Course[] // backrelation only
  hobbies   Hobbies[]
}

model Hobbies {
  id          Int       @id @default(autoincrement())
  name        String
  professorId Int
  professor   Professor @relation(fields: [professorId], references: [id])
}
